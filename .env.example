# Скопируйте в .env и заполните значения:
#   cp .env.example .env
#
# Файл .env не коммитится в git (см. .gitignore).

# API-ключ GigaChat для ИИ-ассистента (обязательно для чата)
# Допустимые имена: GIGACHAT_CREDENTIALS или GIGACHAT_API_KEY
GIGACHAT_CREDENTIALS=

# Модель: GigaChat | GigaChat-Pro | GigaChat-Max
# Допустимое имя: GIGACHAT_MODEL или MODEL
GIGACHAT_MODEL=GigaChat

# Опционально:
# GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# GIGACHAT_API_URL=...          # альтернативное имя для GIGACHAT_BASE_URL
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_TEMPERATURE=0.2
# GIGACHAT_MAX_TOKENS=2048
# GIGACHAT_VERIFY_SSL=false

# Для локальной разработки backend без Docker (в Docker задаётся в docker-compose.yml):
# DATABASE_URL=postgresql+psycopg://roadmap:roadmap@localhost:15432/roadmap
